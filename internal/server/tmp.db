CREATE TABLE creators (    id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,    creator_id CHAR(36) NOT NULL,    creator_name VARCHAR(255) NOT NULL,              email VARCHAR(255) NOT NULL,                     type TINYINT(2) NOT NULL DEFAULT 0 COMMENT '0:email',    password_hash VARCHAR(255) NOT NULL,            role TINYINT(2) NOT NULL DEFAULT 1 COMMENT '0:admin 1:其他',    status TINYINT(2) NOT NULL DEFAULT 0 COMMENT '0:未启用，1:已激活、2:禁用或暂停, 3:已删除',    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    last_login_at TIMESTAMP NULL,    PRIMARY KEY (id),    UNIQUE KEY uk_creator_id (creator_id),    UNIQUE KEY uk_creator_name (creator_name),    UNIQUE KEY uk_email (email),    KEY idx_status (status),    KEY idx_created_at (created_at)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='creators table'; 
CREATE TABLE creator_profiles (    id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,    creator_id CHAR(36) NOT NULL,    nickname VARCHAR(100) NULL COMMENT '昵称',    avatar_url VARCHAR(255) NULL COMMENT '头像地址',    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建时间',    updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '记录更新时间',    PRIMARY KEY (id),    UNIQUE KEY uk_creator_id (creator_id),    KEY idx_created_at (created_at)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='Creator personal information sheet';
CREATE TABLE `creator_sites` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '主键ID',    `creator_id` VARCHAR(36) NOT NULL COMMENT '创作者ID',    `site_id` VARCHAR(36) NOT NULL COMMENT '站点ID',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',    PRIMARY KEY (`id`),    UNIQUE KEY `uk_creator_site` (`creator_id`, `site_id`),    KEY `idx_creator_id` (`creator_id`),    KEY `idx_site_id` (`site_id`)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='用户站点关联表';
CREATE TABLE `sites` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '自增ID',    `site_id` CHAR(36) NOT NULL COMMENT '站点唯一ID',    `domain` VARCHAR(255) NOT NULL COMMENT '基础域名',    `redirect` BOOLEAN DEFAULT FALSE COMMENT '是否强制308重定向',    `path` VARCHAR(255) NOT NULL COMMENT '站点路径',    `name` VARCHAR(1024) NOT NULL COMMENT '站点名称',    `logo` VARCHAR(255) DEFAULT NULL COMMENT 'logo地址',    `status` TINYINT(2) NOT NULL DEFAULT 1 COMMENT '0:未发布 1:已发布 2:停止或下架',    `title` VARCHAR(1024) DEFAULT NULL COMMENT '网站标题',    `description` TEXT DEFAULT NULL COMMENT '网站描述',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    PRIMARY KEY (`id`),    UNIQUE KEY `uk_site_id` (`site_id`),    UNIQUE KEY `uk_path` (`path`),    KEY `idx_status` (`status`)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='站点信息表';
 CREATE TABLE `site_playlists` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '自增ID',    `site_id` CHAR(36) NOT NULL COMMENT '站点ID',    `playlist_id` CHAR(36) NOT NULL COMMENT '播放列表ID',    `status` TINYINT(2) NOT NULL DEFAULT 0 COMMENT '0:生效 1:已删除',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    PRIMARY KEY (`id`),    UNIQUE KEY `uk_site_playlist` (`site_id`, `playlist_id`),    KEY `idx_status` (`status`)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='站点播放列表关联表';
 CREATE TABLE `site_seo` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '自增ID',    `site_id` CHAR(36) NOT NULL COMMENT '站点ID',    `title` VARCHAR(1024) NOT NULL COMMENT 'SEO标题',    `description` TEXT DEFAULT NULL COMMENT 'SEO描述',    `keywords` VARCHAR(1024) DEFAULT NULL COMMENT 'SEO关键词',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    PRIMARY KEY (`id`),    UNIQUE KEY `uk_site_id` (`site_id`)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='站点SEO表';
 CREATE TABLE videos (    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,      -- 自增ID，主键    vid VARCHAR(36) NOT NULL UNIQUE,                    -- 视频唯一标识（UUID），索引，唯一    tags VARCHAR(1024) DEFAULT NULL,                    -- 视频标签，非必填    title VARCHAR(1024) NOT NULL,                       -- 视频标题，必填    description TEXT DEFAULT NULL,                       -- 视频描述，非必填    cover VARCHAR(255) DEFAULT NULL,                     -- 视频封面图，非必填    upload_status TINYINT(2) NOT NULL,                   -- 上传状态：0-未上传，1-上传中，2-上传失败，3-上传成功    status TINYINT(2) NOT NULL,                          -- 视频状态：0-未发布，1-已发布，2-下架，3-删除    video_path VARCHAR(1024) DEFAULT NULL,              -- 视频文件存储路径，非必填    duration INT(11) DEFAULT NULL,                       -- 视频时长，非必填    file_size INT(11) DEFAULT NULL,                      -- 文件大小，非必填    creator_id VARCHAR(36) NOT NULL,                    -- 视频上传者ID（UUID），必填    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP, -- 创建时间，默认当前时间    updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP -- 更新时间，自动更新) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
 CREATE TABLE `video_seo` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '自增ID',    `vid` CHAR(36) NOT NULL COMMENT '视频ID',    `description` TEXT DEFAULT NULL COMMENT 'SEO描述',    `web_video_url` VARCHAR(255) DEFAULT NULL COMMENT '网页播放地址',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    PRIMARY KEY (`id`),    UNIQUE KEY `uk_vid` (`vid`)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='视频SEO表';
 CREATE TABLE `playlists` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '自增ID',    `playlist_id` CHAR(36) NOT NULL COMMENT '专辑ID',    `title` VARCHAR(1024) DEFAULT NULL COMMENT '标题',    `desctiption` TEXT DEFAULT NULL COMMENT '描述',    `tags` VARCHAR(1024) DEFAULT NULL COMMENT '标签',    `cover` VARCHAR(255) DEFAULT NULL COMMENT '封面',    `status` TINYINT(2) NOT NULL DEFAULT 0 COMMENT '0:未发布 1:已发布 2:已下架 3:已删除',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    PRIMARY KEY (`id`),    UNIQUE KEY `uk_playlist_id` (`playlist_id`),    KEY `idx_status` (`status`)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='视频专辑表';
 CREATE TABLE `playlist_seo` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '自增ID',    `playlist_id` CHAR(36) NOT NULL COMMENT '专辑ID',    `title` VARCHAR(1024) NOT NULL COMMENT 'SEO标题',    `description` TEXT DEFAULT NULL COMMENT 'SEO描述',    `web_playlist_url` VARCHAR(255) DEFAULT NULL COMMENT '网页地址',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    PRIMARY KEY (`id`),    UNIQUE KEY `uk_playlist_id` (`playlist_id`)) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='专辑SEO表';
 CREATE TABLE `playlist_vid` (    `id` BIGINT UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '自增ID',    `playlist_id` CHAR(36) NOT NULL COMMENT '专辑ID',    `vid` CHAR(36) NOT NULL COMMENT '视频ID',    `sort_number` DECIMAL(20,10) NOT NULL COMMENT '排序权重',    `created_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,    `updated_at` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,    PRIMARY KEY (`id`),    UNIQUE KEY `uk_playlist_vid` (`playlist_id`, `vid`),    KEY `idx_playlist_sort` (`playlist_id`, `sort_number`) COMMENT '优化排序查询') ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='专辑-视频关联表';
 
